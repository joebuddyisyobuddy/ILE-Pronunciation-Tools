{
  "manifest_version": 3,
  "name": "ILE Phonetic Coach",
  "version": "0.2.0",
  "description": "Pronunciation analysis for the ILE language learning platform. Compares your speech against native reference audio using phoneme recognition, pitch, and rhythm analysis.",
  "permissions": [
    "activeTab",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "*://*.ile.io/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.ile.io/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": [
        "lib/pitch-detector.js",
        "lib/spectral-analysis.js",
        "lib/audio-analyzer.js",
        "lib/comparison.js",
        "content.js"
      ],
      "css": [
        "panel.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html"],
      "matches": ["*://*.ile.io/*", "*://localhost/*", "*://127.0.0.1/*"]
    }
  ]
}
